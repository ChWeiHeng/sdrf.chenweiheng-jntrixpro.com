<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>ButtonBar</field>
        <field>Customer__c</field>
        <field>Overdue__c</field>
        <field>Ultra_Credit__c</field>
        <field>SAP_Credit_Limit__c</field>
        <field>Owner</field>
        <field>Total_Amount__c</field>
        <field>Order_Amount_Guide__c</field>
        <field>Amount_Difference__c</field>
        <field>Amount_Rate__c</field>
        <field>Total_Margin__c</field>
        <field>Margin_Rate__c</field>
        <field>Total_Estimate_Margin__c</field>
        <field>Total_Margin_Estimate_Rate__c</field>
        <field>Total_Margin_Level__c</field>
        <field>Order_type__c</field>
        <field>Currency__c</field>
        <field>Terms_Of_Payment__c</field>
        <field>Commission_Amount_New__c</field>
        <field>Commission_Percentage__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <description>如果是经理提交跳过该步骤</description>
        <entryCriteria>
            <formula>CONTAINS($UserRole.Name, &apos;Sales Rep&apos;)</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Sales leader</label>
        <name>Sales_Leader</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>martin.agramunt@agroterrum.com.ar</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <description>物流审批</description>
        <label>Logistic</label>
        <name>Logistics</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>bernardo.jacquelin@rainbowagro.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Credit Control</label>
        <name>Credit_Control</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>pablo.torasso@agroterrum.com.ar</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>General Manager</label>
        <name>GM_Pablo</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>eric_wang@rainbowagro.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Area Head</label>
        <name>Area_Head</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <description>阿根廷寄售订单ZARE 修改价格</description>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Order__c.Status__c</field>
            <operation>equals</operation>
            <value>Draft,Rejected</value>
        </criteriaItems>
        <criteriaItems>
            <field>Order__c.Order_type__c</field>
            <operation>equals</operation>
            <value>ZARE</value>
        </criteriaItems>
        <criteriaItems>
            <field>Order__c.RecordType</field>
            <operation>equals</operation>
            <value>Model C</value>
        </criteriaItems>
        <criteriaItems>
            <field>Order__c.Is_YPF__c</field>
            <operation>notEqual</operation>
            <value>True</value>
        </criteriaItems>
        <criteriaItems>
            <field>Order__c.Change_Guide_Price_Item__c</field>
            <operation>greaterThan</operation>
            <value>0</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>OrderApproved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>OrderApproveFailed</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>OrderApproving</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Consignment AR C ZARE(Change price)</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>21</processOrder>
    <recallActions>
        <action>
            <name>OrderDraft</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
