<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Phone_Number</fullName>
    <active>true</active>
    <errorConditionFormula>REGEX(Telephone__c, &quot;.*[A-Za-z].*&quot;)</errorConditionFormula>
    <errorDisplayField>Telephone__c</errorDisplayField>
    <errorMessage>It&apos;s not a phone number</errorMessage>
</ValidationRule>
