<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Quotation_Type_Not_Allow_Change</fullName>
    <active>true</active>
    <errorConditionFormula>AND(Quote_Detail_Count__c&gt;0,ISCHANGED(Quotation_Type__c))</errorConditionFormula>
    <errorMessage>You cannot update the quotation type since you have already added quotation details</errorMessage>
</ValidationRule>
