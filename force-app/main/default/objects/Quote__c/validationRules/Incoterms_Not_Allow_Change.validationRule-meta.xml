<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Incoterms_Not_Allow_Change</fullName>
    <active>true</active>
    <errorConditionFormula>AND(Quote_Detail_Count__c&gt;0,ISCHANGED(Incoterms__c),TEXT(Sales_Org__c)=&apos;3010&apos;)</errorConditionFormula>
    <errorDisplayField>Incoterms__c</errorDisplayField>
    <errorMessage>You cannot update the Incoterms since you have already added quotation details</errorMessage>
</ValidationRule>
