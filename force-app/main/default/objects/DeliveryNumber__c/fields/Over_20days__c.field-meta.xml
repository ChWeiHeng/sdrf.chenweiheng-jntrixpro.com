<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Over_20days__c</fullName>
    <description>The calculation to determine whether the invoice has been uploaded within 20 days.</description>
    <formula>(TODAY()-Delivery_Post_Date__c) &gt; 20</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Over 20days</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
