<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Is_This_Week__c</fullName>
    <formula>Order__r.Approve_Date__c &gt;= (TODAY()-IF(WEEKDAY(TODAY())=1,WEEKDAY(TODAY())+7,WEEKDAY(TODAY()))+2) &amp;&amp; Order__r.Approve_Date__c &lt;= TODAY()-IF(WEEKDAY(TODAY())=1,WEEKDAY(TODAY())+7,WEEKDAY(TODAY()))+8</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Is This Week</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
