<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Margin_Report__c</fullName>
    <externalId>false</externalId>
    <formula>IF(
(TEXT(Order__r.Status__c)!=&apos;Approved&apos;),
0,
IF(
isClosed__c,
 Margin__c * Bill_Quantity__c ,
 Margin__c * Quantity__c 
)
)</formula>
