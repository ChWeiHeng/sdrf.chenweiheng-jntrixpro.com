<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Validate_Actual_Cost</fullName>
    <active>true</active>
    <errorConditionFormula>AND(TEXT(MKT_Approval__c)==&apos;Approved&apos;,Budget__c!=Actual_Costs__c,ISCHANGED(Budget__c))</errorConditionFormula>
