<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Can_Not_Change_Reason</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISCHANGED(Order_Reason__c) , Order_Item_Number__c &gt;0,TEXT(Order_type__c)=&apos;ZMX3&apos;)</errorConditionFormula>
    <errorDisplayField>Order_Reason__c</errorDisplayField>
    <errorMessage>Can&apos;t change reason, please remove order item</errorMessage>
</ValidationRule>
