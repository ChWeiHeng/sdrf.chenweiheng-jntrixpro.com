<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Cannot_Change_Order_Currency</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISCHANGED(Currency__c) , Order_Item_Number__c &gt;0)</errorConditionFormula>
    <errorDisplayField>Currency__c</errorDisplayField>
    <errorMessage>Cannot change order currency, please remove order item</errorMessage>
</ValidationRule>
