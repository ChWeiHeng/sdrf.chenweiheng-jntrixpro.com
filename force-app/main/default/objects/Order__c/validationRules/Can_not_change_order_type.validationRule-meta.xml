<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Can_not_change_order_type</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISCHANGED(Order_type__c) ,NOT(ISBLANK(Quotes__c)))</errorConditionFormula>
    <errorMessage>You can&apos;t update the order type since you have already added order details</errorMessage>
</ValidationRule>
