<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Can_not_Change_Type</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISCHANGED(Order_type__c) ,Order_Item_Number__c!=0)</errorConditionFormula>
    <errorMessage>Order has items,order type can&apos;t change</errorMessage>
</ValidationRule>
