<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Margin_Rate__c</fullName>
    <formula>IF(
OR(TEXT(Deliver_Plant__c)=&apos;3011&apos;,TEXT(Deliver_Plant__c)=&apos;3020&apos;),
(Total_Margin__c / Total_Cash_Price__c ),
				IF(
								TEXT(Order_type__c)=&apos;ZARL&apos;,
								0,
								(Total_Margin__c / Total_Price__c )
								
				)
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Total Margin Rate</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
