            .applicant-td { border: #000000 1px solid; padding:5px; }
            .applicant { table-layout: fixed; width: 100%; }
            .first-row { text-align: center; background-color: rgb(174, 161, 161); font-weight: bold; }
            .first-col { background-color: rgb(174, 161, 161); width: 20%;}
            .rep td { border: #000000 1px solid; font-size: 12px; padding: 2px; }
            .relate-busi td { border: #000000 1px solid; font-size: 12px; text-align: center; font-weight: bold; }
            .banker td { border: #000000 1px solid; font-size: 12px; text-align: center; }
            .trading-ref td { border: #000000 1px solid; font-size: 12px; text-align: center; }
            .privacy td { font-size: 12px; }
            .sign-req td { font-size: 12px; }
            .sign-prename td { font-size: 12px; border: #000000 1px solid; }
            .blank-row { height: 30px; }
            .office-sign td { border: #000000 1px solid; font-size: 12px; vertical-align: bottom; padding-left: 5px;}
            .office-sign tr { height: 40px; }
            .guarantee p { font-size: 12px; }
            .double-col { width: 100%; font-size: 10px; }
            .signsheet tr { height: 40px; }
            .signsheet td { width: 50%; vertical-align: top; padding-left: 10px; border-bottom-style: solid; font-size: 12px; }
            .trading-ref td {text-align: left; padding: 5px;}
