        <div>&nbsp;Lugar: <span style="text-decoration: inline;">{!order.Customer__r.Tax_Number__c}</span></div><br/>
        <div>&nbsp;Día de entrega: <span style="text-decoration: inline;">{!order.Customer_Shipping_Address__r.Direction__c}</span></div><br/>
        <div>&nbsp;Condicion de venta: <span style="text-decoration: inline;">{!order.Name}</span></div><br/>
        <div>&nbsp;Fecha Documento: <span style="text-decoration: inline;">{!order.CreatedDate_Text__c}</span></div><br/>
    </div>
    <div align="center" class="hr-line" style="border-top: 1px solid black;background-color:rgb(112, 173, 71);"></div>
    <div  style="border-top:solid;border-width:1px;" >
        <div>&nbsp;Información parte vendedora</div><br/>
        <div>&nbsp;Razón social: <span style="text-decoration: inline;">{!order.Customer__r.MDG_Customer_Code__c}</span></div><br/>
