    <br/>
    <div align="center" class="hr-line" style="border-top: 1px solid black;background-color:rgb(112, 173, 71);"></div>
    <div  style="border-top:solid;border-width:1px;" >
        <div>&nbsp;C/V .: <span style="text-decoration: inline;">{!order.Customer__r.Name}</span></div><br/>
