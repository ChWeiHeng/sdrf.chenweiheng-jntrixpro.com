global without sharing class SetTaxBatch implements Database.Batchable<sObject>,Database.Stateful,Schedulable {
    public String query='SELECT Tax_Category_Master_Data__c,Sales_View__r.Sales_Org__c,Sales_View__r.Distr_Channel__c,Id,Tax_Category__c,Sales_View__r.External_ID__c,Sales_View__r.Customer__r.Original_Customer__c FROM Customer_Tax_Category__c WHERE Sales_View__r.Customer__r.Original_Customer__c!=null';
    global void execute(SchedulableContext sc) {
        SetTaxBatch svo = new SetTaxBatch();

        // 每次执行多少条数据，最大100
        String jobId = Database.executeBatch(svo, 100);
    } 

    global Database.QueryLocator start(Database.BatchableContext bc) {
        return Database.getQueryLocator(query);
    }

    global void execute(Database.BatchableContext BC, List<Customer_Tax_Category__c> ctcList) {
        Set<String> externalIdSet = new Set<String>();
        for(Customer_Tax_Category__c csi : ctcList) {
            externalIdSet.add(csi.Sales_View__r.Customer__r.Original_Customer__c+'_'+csi.Sales_View__r.Sales_Org__c+'_'+csi.Sales_View__r.Distr_Channel__c);
        }
        Map<String,String> taxCategoryMap = new Map<String,String>();
        for(Customer_Tax_Category__c ctc : [SELECT Tax_Category_Master_Data__c,Sales_View__r.External_ID__c,Tax_Category__c FROM Customer_Tax_Category__c WHERE Sales_View__r.External_ID__c IN:externalIdSet]) {
            taxCategoryMap.put(ctc.Sales_View__r.External_ID__c+'_'+ctc.Tax_Category_Master_Data__c,ctc.Tax_Category__c);
        }
        for(Customer_Tax_Category__c csi : ctcList) {
            String exc = csi.Sales_View__r.Customer__r.Original_Customer__c+'_'+csi.Sales_View__r.Sales_Org__c+'_'+csi.Sales_View__r.Distr_Channel__c+'_'+csi.Tax_Category_Master_Data__c;
            csi.Tax_Category__c = taxCategoryMap.get(exc);
        }
        Database.update(ctcList,false);
    }

    global void finish(Database.BatchableContext BC) {
    }

