global without sharing class CreateShipAccountBatch implements Database.Batchable<sObject>,Database.Stateful,Schedulable {
    public String query = 'SELECT Id FROM Customer_Sales_Info__c WHERE Sales_View_Status__c=\'Approved\'';
    global void execute(SchedulableContext sc) {
        CreateShipAccountBatch svo = new CreateShipAccountBatch();

        // 每次执行多少条数据，最大100
        String jobId = Database.executeBatch(svo, 100);
    } 

    global Database.QueryLocator start(Database.BatchableContext bc) {
        return Database.getQueryLocator(query);
    }

    global void execute(Database.BatchableContext BC, List<Customer_Sales_Info__c> accList) {
        for(Customer_Sales_Info__c csi : accList) {
            Approval.lock(csi.Id);
        }
    }

    global void finish(Database.BatchableContext BC) {
    }
